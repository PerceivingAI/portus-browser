{
  "broker": {
    "host": "127.0.0.1",
    "port": 17345,
    "transport": "local",
    "pipeName": "portus-browser-broker",
    "sessionIdPrefix": "br",
    "heartbeatIntervalMs": 5000,
    "sessionTimeoutMs": 20000,
    "commandTimeoutMs": 15000,
    "defaultTargetStrategy": "oldest",
    "allowRemoteConnections": false,
    "logLevel": "info"
  },
  "nativeHost": {
    "name": "com.portus.browser",
    "brokerPipeName": "portus-browser-broker",
    "startBrokerIfMissing": true,
    "connectTimeoutMs": 5000,
    "allowedExtensionOrigins": []
  },
  "cli": {
    "output": "table",
    "color": "auto",
    "defaultBrowser": null,
    "failWhenMultipleBrowsers": false,
    "showUrls": true,
    "truncateTitles": true,
    "truncateWidth": 80
  },
  "extension": {
    "autoRegister": true,
    "bridgeAutoConnect": false,
    "heartbeatEnabled": true,
    "showSidePanelStatus": true,
    "enableTerminalPanel": true,
    "browserLabel": null,
    "permissionsMode": "minimal"
  },
  "sessions": {
    "idFormat": "prefix-counter",
    "defaultTargetStrategy": "oldest",
    "sortBrowsersBy": "connectedAt",
    "expireDisconnectedAfterMs": 20000,
    "rememberBrowserAliases": true
  },
  "tabs": {
    "ordering": "window-order-then-tab-index",
    "indexBase": 1,
    "includePinnedTabs": true,
    "includeDiscardedTabs": true,
    "showWindowId": true
  },
  "commands": {
    "timeoutMs": 15000,
    "confirmCloseWindow": true,
    "confirmCloseMultipleTabs": true,
    "openUrlActiveByDefault": true,
    "normalizeUrls": true
  },
  "security": {
    "allowedOrigins": [
      "chrome-extension://<extension-id>"
    ],
    "requireLocalhost": true,
    "requireBrokerToken": true,
    "tokenStorage": "user-config",
    "allowPageScriptExecution": false,
    "allowDebuggerApi": false,
    "allowDebuggerApiRequiresConfirmation": true
  },
  "permissions": {
    "hostPermissionMode": "optional-per-site",
    "defaultAllowlist": [],
    "allowlistStorage": "user-config",
    "activeTabFallback": true,
    "requireConfirmationForNewOrigins": true
  },
  "events": {
    "enabled": true,
    "retentionLimit": 1000,
    "includeSnapshotInvalidation": true,
    "includePermissionEvents": true
  },
  "logging": {
    "level": "info",
    "file": true,
    "console": true,
    "redactUrls": false,
    "redactTitles": false,
    "maxLogFiles": 5
  },
  "terminal": {
    "enabled": true,
    "defaultProfileId": "auto",
    "manualTerminalPath": null,
    "startupCommand": null,
    "defaultWorkingDirectory": "Downloads/portus-session",
    "fontSize": 16,
    "maxSessions": 5,
    "idleTimeoutMs": 1800000
  }
}
