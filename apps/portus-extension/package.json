{
  "name": "@portus/extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tailwindcss -i src/gui/styles.css -o dist/gui.css --minify && esbuild src/background.ts --bundle --format=esm --platform=browser --target=chrome120 --outfile=dist/background.js && esbuild src/popup.tsx --bundle --format=esm --platform=browser --target=chrome120 --outfile=dist/popup.js && esbuild src/sidepanel.tsx --bundle --format=esm --platform=browser --target=chrome120 --outfile=dist/sidepanel.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:runtime": "pnpm build && node --test tests/*.test.mjs",
    "test:gui": "vitest run --config vitest.config.ts",
    "test": "pnpm test:runtime && pnpm test:gui",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@portus/actions": "workspace:*",
    "@portus/permissions": "workspace:*",
    "@portus/protocol": "workspace:*",
    "@portus/snapshots": "workspace:*",
    "@portus/terminal": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@portus/broker": "workspace:*",
    "@portus/native-host": "workspace:*",
    "@portus/native-messaging": "workspace:*",
    "@portus/transport": "workspace:*",
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "vitest": "^4.1.6"
  }
}
